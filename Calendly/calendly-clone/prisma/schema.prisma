generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String   @id @default(cuid())
  username String   @unique
  email    String   @unique
  password String
  bookings Booking[]
}

model Booking {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  // Add these two lines:
  guestName  String
  guestEmail String
  startTime  DateTime
  endTime    DateTime
}